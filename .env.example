# ── App ──────────────────────────────────────────────────────────────────
VITE_APP_ID=wandai
NODE_ENV=production
PORT=5000

# ── Auth / Sessions ─────────────────────────────────────────────────────
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ── Database (MySQL) ────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/wandai

# ── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── AWS S3 (file storage) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ── Hostaway ────────────────────────────────────────────────────────────
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_API_KEY=

# ── Breezeway ───────────────────────────────────────────────────────────
BREEZEWAY_CLIENT_ID=
BREEZEWAY_CLIENT_SECRET=

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_LIVE_KEY=
# STRIPE_SECRET_KEY=            # fallback if STRIPE_LIVE_KEY not set

# ── Gmail (Viv email concierge) ─────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Slack ───────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Google OAuth ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
